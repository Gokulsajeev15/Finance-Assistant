# Finance Assistant Environment Configuration
# Copy this file to .env and update the values as needed

# Stock Data
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# AI Provider — use one at a time
# HF free tier (active): get your token at huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# OpenAI paid (comment HF_TOKEN above and uncomment this when you have a key)
# OPENAI_API_KEY=your_openai_api_key_here

# PostgreSQL — conversation memory
# Install: brew install postgresql@16 && brew services start postgresql@16
# Create DB: psql postgres -c "CREATE DATABASE finance_assistant;"
DATABASE_URL=postgresql+asyncpg://your_username@localhost/finance_assistant

# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=true

# Frontend Configuration  
FRONTEND_URL=http://localhost:3000

# Data Configuration
COMPANY_UPDATE_INTERVAL_HOURS=6
MAX_COMPANIES=100

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
